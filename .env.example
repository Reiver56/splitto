# Connessione al database PostgreSQL.
# Puoi usare DATABASE_URL oppure i singoli parametri sotto (DATABASE_URL ha la precedenza se impostata).
# DATABASE_URL=postgresql://splitto:splitto@localhost:5432/splitto

DB_HOST=localhost
DB_PORT=5432
DB_NAME=splitto
DB_USER=splitto
DB_PASSWORD=splitto

# Chiavi VAPID per le notifiche Web Push.
# Generale con: python generate_vapid_keys.py
# Il comando crea il file vapid_private_key.pem e stampa il valore da incollare qui sotto.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY_FILE=vapid_private_key.pem
# Email/contatto richiesto dallo standard VAPID (formato mailto:)
VAPID_CLAIM_EMAIL=mailto:admin@example.com

# Porta su cui gira il server Flask.
# 5000 = nessun privilegio richiesto, l'URL deve includere la porta (es. https://splitto.local:5000).
# 443  = porta HTTPS standard, l'URL non deve indicare la porta (es. https://splitto.local),
#        ma su Windows richiede di eseguire "python app.py" da un terminale come Amministratore.
FLASK_PORT=443

# Orario del promemoria giornaliero per le bollette in scadenza (formato HH:MM, 24h)
REMINDER_HOUR=9
REMINDER_MINUTE=0
